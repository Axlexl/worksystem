{
  "name": "worksystem",
  "private": true,
  "version": "1.0.0",
  "description": "WorkSystem — Construction Management Desktop App",
  "author": "WorkSystem",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "set ELECTRON_DEV=1 && npx electron .",
    "electron:build": "npm run build && npx electron-builder --win"
  },
  "build": {
    "appId": "com.worksystem.app",
    "productName": "WorkSystem",
    "copyright": "Copyright © 2025 WorkSystem",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/favicon.svg",
      "uninstallerIcon": "public/favicon.svg",
      "installerHeaderIcon": "public/favicon.svg",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WorkSystem"
    },
    "extraResources": [
      {
        "from": "node_modules/better-sqlite3/build/Release",
        "to": "better-sqlite3/build/Release",
        "filter": [
          "**/*.node"
        ]
      }
    ],
    "asar": true,
    "compression": "maximum"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "axios": "^1.18.1",
    "better-sqlite3": "^12.11.1",
    "dayjs": "^1.11.21",
    "nodemailer": "6.9.14",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.18.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.5.0",
    "electron-builder": "^25.1.8",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "vite": "^8.1.0"
  }
}
