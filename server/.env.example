# Copy this to .env and fill in your values

# Server
PORT=4000

# JWT — use a long random string (min 32 chars)
JWT_SECRET=change_this_to_a_very_long_random_secret_key_123
JWT_EXPIRES_IN=8h

# Admin Portal secret (software owner access)
ADMIN_SECRET=change_this_admin_secret_key

# Email (use Gmail App Password or any SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=WorkSystem <your_email@gmail.com>

# App URL (used in reset links)
APP_URL=http://localhost:5173
